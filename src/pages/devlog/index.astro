---
import { getCollection } from 'astro:content';
import DevlogCard from '../../components/DevlogCard.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';

const posts = (await getCollection('devlog', ({ data }) => !data.draft)).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---
<BaseLayout title="Devlog | Voidless Tale" description="Development updates for Voidless Tale.">
  <section class="panel">
    <p class="kicker">Development updates</p>
    <h1>Devlog</h1>
    <p>Progress notes, feature breakdowns, and production updates.</p>
  </section>
  <section class="devlog-grid">
    {posts.map((post) => <DevlogCard href={`/devlog/${post.id}/`} title={post.data.title} date={post.data.pubDate} excerpt={post.data.description} tags={post.data.tags ?? []} />)}
  </section>
</BaseLayout>
