---
const title = 'Fresh rebuild';
const description = 'The Voidless Tale website has been rebuilt cleanly.';
const pubDate = '2026-05-04';
const draft = false;
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout title={title} description={description}>
  <article class="section">
    <p><strong>Published:</strong> {pubDate} · <strong>Draft:</strong> {String(draft)}</p>
    <p>The Voidless Tale website has been rebuilt cleanly with Astro and a future-ready Sveltia CMS route.</p>
  </article>
</BaseLayout>
