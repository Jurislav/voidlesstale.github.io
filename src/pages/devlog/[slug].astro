---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('devlog', ({ data }) => !data.draft);
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---
<BaseLayout title={`${post.data.title} | Voidless Tale`} description={post.data.description}>
  <article class="panel prose centered-prose">
    <a class="back-link" href="/devlog/">← Back to Devlog</a>
    <h1>{post.data.title}</h1>
    <p class="muted">{post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</p>
    <Content />
  </article>
</BaseLayout>
