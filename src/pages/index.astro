---
import { getCollection } from 'astro:content';
import CTAButton from '../components/CTAButton.astro';
import DevlogCard from '../components/DevlogCard.astro';
import FeatureCard from '../components/FeatureCard.astro';
import MediaPlaceholder from '../components/MediaPlaceholder.astro';
import SectionPanel from '../components/SectionPanel.astro';
import TagPill from '../components/TagPill.astro';
import BaseLayout from '../layouts/BaseLayout.astro';

const latestPosts = (await getCollection('devlog', ({ data }) => !data.draft)).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()).slice(0, 3);
---
<BaseLayout title="Voidless Tale" description="Voidless Tale dark fantasy RPG and development updates.">
  <section class="hero-grid panel">
    <div>
      <p class="kicker">Dark fantasy pixel RPG</p>
      <h1>Voidless Tale</h1>
      <p>A clean, focused indie game page for following development through Heaven, Hell, and everything in between.</p>
      <div class="tag-row"><TagPill label="Pixel RPG" /><TagPill label="Godot" /><TagPill label="C#" /><TagPill label="Solo Dev" /><TagPill label="In Development" /></div>
      <div class="cta-row"><CTAButton href="/devlog/">Read Devlog</CTAButton><CTAButton href="/smith/" variant="ghost">View Voidless Smith</CTAButton><CTAButton href="/devlog/" variant="ghost">Follow Development</CTAButton></div>
    </div>
    <MediaPlaceholder image="/uploads/hero_img.png" alt="Voidless Tale preview" label="Voidless Tale" />
  </section>
  <SectionPanel><h2>About Voidless Tale</h2><p>Voidless Tale is a 2D pixel RPG with soulslike pressure, platforming movement, and a world split between Heaven and Hell.</p></SectionPanel>
  <section class="feature-grid"> 
    <FeatureCard title="Branching world" text="Explore layered zones tied to sin, memory, and redemption." />
    <FeatureCard title="Tight combat" text="Fast reads, punishing bosses, and skill-first progression." />
    <FeatureCard title="Solo built" text="Designed and developed by Juris / srcgames in Godot + C#." />
  </section>
  <SectionPanel><h2>Screenshot Preview</h2><MediaPlaceholder image="/uploads/hero_img.png" alt="Screenshot preview" /></SectionPanel>
  <section><h2>Latest Devlog</h2><div class="devlog-grid">{latestPosts.map((p)=><DevlogCard href={`/devlog/${p.id}/`} title={p.data.title} date={p.data.pubDate} excerpt={p.data.description} tags={p.data.tags ?? []} />)}</div></section>
  <SectionPanel><h2>Voidless Smith</h2><p>Generate and edit pixel weapons for rapid prototyping and modding workflows.</p><CTAButton href="/smith/">Open Voidless Smith Page</CTAButton></SectionPanel>
  <SectionPanel><h2>Follow Development</h2><p>Track progress through regular devlog updates and milestone posts.</p><CTAButton href="/devlog/">Go to Devlog</CTAButton></SectionPanel>
</BaseLayout>
