---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionCard from '../components/SectionCard.astro';
---
<BaseLayout title="Voidless Tale" description="Between Heaven and Hell, your choices echo.">
  <section class="hero">
    <h1>Voidless Tale</h1>
    <p>Between Heaven and Hell, your choices echo.</p>
    <div class="button-row">
      <a class="button" href="/devlog/">View Devlog</a>
      <a class="button secondary" href="/smith/">Voidless Smith</a>
    </div>
  </section>
  <section class="grid">
    <SectionCard title="About the game" text="Voidless Tale is a 2D pixel RPG inspired by MapleStory-style side-scrolling movement, Ragnarok-like progression, Heaven vs Hell themes, the seven deadly sins, loot, crafting, boss doors, skill absorption, and solo/co-op RPG progression." />
    <SectionCard title="Heaven vs Hell" text="Two mirrored realms pull the player toward different endings, bosses, and choices." />
    <SectionCard title="Seven Deadly Sins" text="Each sin becomes a domain, a memory, and a boss encounter." />
    <SectionCard title="Loot, Crafting, Skill Absorption" text="Every enemy can become a source of items, progression, or absorbed power." />
    <SectionCard title="Voidless Smith" text="Voidless Smith supports the tool side of the project, starting with pixel weapon generation and growing toward SDK/modding workflows." />
  </section>
</BaseLayout>
