---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const latestPosts = (await getCollection('devlog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<BaseLayout
  title="Voidless Tale"
  description="Official site and devlog for Voidless Tale, rebuilt with Astro and Sveltia CMS."
>
  <section class="page-section hero">
    <div class="hero__panel">
      <span class="eyebrow">Dark fantasy action RPG</span>
      <h1>Voidless Tale now has a clean Astro foundation.</h1>
      <p>
        This rebuild gives you a static site that is easy to ship on Cloudflare Pages and easy
        to update through Sveltia CMS without dragging a custom backend into the project.
      </p>
      <div class="hero__actions">
        <a class="button-link button-link--primary" href="/cms/">Open CMS</a>
        <a class="button-link" href="/devlog/">Read the devlog</a>
      </div>
    </div>

    <div class="hero__panel">
      <span class="eyebrow">What is included</span>
      <div class="stats-grid">
        <article class="card">
          <h3>Static-first</h3>
          <p>Astro builds plain HTML output that Cloudflare Pages can host directly.</p>
        </article>
        <article class="card">
          <h3>Git-backed CMS</h3>
          <p>Sveltia edits Markdown content in your repository instead of relying on a database.</p>
        </article>
        <article class="card">
          <h3>Editor-ready</h3>
          <p>The `/cms/` route is wired to your devlog collection and media uploads folder.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="page-section">
    <span class="eyebrow">Latest updates</span>
    <h2>Recent devlog posts</h2>
    <div class="card-grid">
      {latestPosts.map((post) => (
        <a class="card" href={`/devlog/${post.id}/`}>
          <time datetime={post.data.pubDate.toISOString()}>
            {post.data.pubDate.toLocaleDateString('en-US', {
              year: 'numeric',
              month: 'long',
              day: 'numeric',
            })}
          </time>
          <h3>{post.data.title}</h3>
          <p>{post.data.description}</p>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
