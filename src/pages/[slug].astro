---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const pages = await getCollection('pages', ({ data }) => !data.draft);

  return pages.map((page) => ({
    params: { slug: page.id },
    props: { page },
  }));
}

const { page } = Astro.props;
const { Content } = await render(page);
const pageTemplate = page.data.template ?? 'default';
const wrapperClass =
  pageTemplate === 'narrow'
    ? 'prose prose--narrow'
    : pageTemplate === 'feature'
      ? 'prose prose--feature'
      : 'prose';
---

<BaseLayout title={`${page.data.title} | Voidless Tale`} description={page.data.description}>
  <section class={`page-section ${wrapperClass}`}>
    <article class="hero__panel page-panel">
      <span class="eyebrow">{page.data.eyebrow ?? page.data.navLabel ?? 'Page'}</span>
      <h1>{page.data.title}</h1>
      <Content />
    </article>
  </section>
</BaseLayout>
