<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex" />
    <title>Voidless Tale CMS</title>
    <link href="/cms/config.yml" type="application/yaml" rel="cms-config-url" />
    <style>
      :root {
        color-scheme: dark;
        font-family: Georgia, "Times New Roman", serif;
      }

      body {
        margin: 0;
        min-height: 100vh;
        display: grid;
        place-items: center;
        background:
          radial-gradient(circle at top, rgba(179, 90, 58, 0.24), transparent 32%),
          #16070d;
        color: #f6ede4;
      }

      .status {
        width: min(32rem, calc(100vw - 3rem));
        padding: 1.25rem 1.5rem;
        border: 1px solid rgba(246, 237, 228, 0.16);
        border-radius: 1rem;
        background: rgba(35, 11, 19, 0.92);
        box-shadow: 0 24px 60px rgba(0, 0, 0, 0.35);
      }

      h1 {
        margin: 0 0 0.5rem;
        font-size: 1.5rem;
      }

      p {
        margin: 0.5rem 0 0;
        line-height: 1.6;
      }

      a {
        color: #ff9c63;
      }
    </style>
  </head>
  <body>
    <main class="status" id="cms-status">
      <h1>Loading CMS…</h1>
      <p id="cms-message">Starting the editor.</p>
    </main>
    <noscript>Sveltia CMS requires JavaScript.</noscript>
    <script>
      const status = document.getElementById('cms-status');
      const configUrl = '/cms/config.yml';

      const showError = (title, text) => {
        if (!status) return;
        status.innerHTML = `
          <h1>${title}</h1>
          <p>${text}</p>
          <p><a href="${configUrl}">Open config.yml</a></p>
        `;
      };

      const loadScript = (src) =>
        new Promise((resolve, reject) => {
          const script = document.createElement('script');
          script.src = src;
          script.async = true;
          script.onload = resolve;
          script.onerror = reject;
          document.body.appendChild(script);
        });

      (async () => {
        try {
          await loadScript('https://cdn.jsdelivr.net/npm/@sveltia/cms/dist/sveltia-cms.js');
        } catch {
          try {
            await loadScript('https://unpkg.com/@sveltia/cms/dist/sveltia-cms.js');
          } catch {
            showError('CMS bundle failed to load', 'The browser could not reach the Sveltia CMS script from either CDN.');
            return;
          }
        }

        try {
          if (window.CMS?.init) {
            await window.CMS.init();
          }
        } catch (error) {
          showError('CMS init failed', error?.message || 'Unknown initialization error.');
        }
      })();
    </script>
  </body>
</html>
