---
const links = [
  { href: '/', label: 'Home' },
  { href: '/devlog/', label: 'Devlog' },
  { href: '/about/', label: 'About' },
];
---

<nav class="site-nav" aria-label="Primary">
  <a class="site-nav__brand" href="/">Voidless Tale</a>
  <div class="site-nav__links">
    {links.map((link) => (
      <a href={link.href}>{link.label}</a>
    ))}
  </div>
</nav>
