---
import { getEntry } from 'astro:content';

const settings = await getEntry('settings', 'settings');
const footerText = settings?.data.footer_text ?? 'Built with Astro and Sveltia CMS.';
---

<footer class="site-footer">
  <div class="site-footer__divider" aria-hidden="true"></div>
  <div class="site-footer__shell">
    <p>{footerText}</p>
  </div>
</footer>
